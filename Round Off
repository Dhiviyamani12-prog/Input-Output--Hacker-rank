Write a program to get a float value from the user and display it in the below-mentioned format.

HINT: Use ceil() and floor() functions from the header file.

Input Format

Input consists of one float value.

Constraints

NA

Output Format

The output consists of one integer, its rounded-up value, and its rounded-down value.

Sample Input 0

54.5
Sample Output 0

54
55
54
Sample Input 1

66.7
Sample Output 1

66
67
66

--------------------------------------------------------------------------------

#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    float num;
    
    scanf("%f",&num);
    int ans = (int)num;
    int ans2=ceil(num);
    int ans3=floor(num);
    printf("%d",ans);
    printf("\n%d",ans2);
    printf("\n%d",ans3);
    
    return 0;
}
